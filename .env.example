# PostgreSQL connection string
# Usa Neon (neon.tech), Supabase o Railway para la BD en la nube
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Palabras clave de búsqueda en BOE (separadas por coma)
BOE_KEYWORDS=energía,eléctrico,gas natural,renovables,hidrocarburo,tarifas eléctricas,mercado eléctrico,CNMC,REE,regulación energética

# Claude API (generate_summaries.py) — opcional
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (generate_ree_analysis.py) — modelo local, no necesita clave
# Instalar: https://ollama.com/download  |  Descargar modelo: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
